{
  "name": "mowojang-cli",
  "version": "0.4.8",
  "description": "CLI Wrapper for the mowojang npm package.",
  "type": "module",
  "bin": {
    "mowojang": "./dist/index.js",
    "mowojang-cli": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm tsc",
    "test": "pnpm build && pnpm i -g .",
    "prettier:check": "pnpm dlx prettier . --check",
    "prettier:write": "pnpm dlx prettier . --write",
    "prepare": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pixelicc/mowojang-cli"
  },
  "keywords": [
    "Mowojang",
    "CLI"
  ],
  "author": "Pixelic",
  "license": "MIT",
  "dependencies": {
    "mowojang": "0.4.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
